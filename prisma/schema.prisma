generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Amenity {
  id              String           @id
  name            String
  iconKey         String
  iconUrl         String?
  isActive        Boolean          @default(true)
  categoryId      String?
  createdAt       DateTime         @default(now())
  AmenityCategory AmenityCategory? @relation(fields: [categoryId], references: [id])
  HomeAmenity     HomeAmenity[]
}

model AmenityCategory {
  id        String    @id
  name      String
  order     Int?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  Amenity   Amenity[]
}

model AuditLog {
  id        String   @id
  action    String
  userId    String
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Banner {
  id          String     @id
  title       String
  startDate   DateTime
  endDate     DateTime
  url         String
  clientPhone String
  clientEmail String
  cost        Float
  createdById String
  createdAt   DateTime   @default(now())
  imageUrl    String
  updatedAt   DateTime
  tipo        BannerTipo @default(HERO1)
  User        User       @relation(fields: [createdById], references: [id])
}

model Favorite {
  id       String   @id
  userId   String
  homeId   String
  createAt DateTime @default(now())
  Home     Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
  User     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, homeId])
}

model Home {
  id                      String         @id
  title                   String?
  description             String?
  guests                  String?
  bedrooms                String?
  bathrooms               String?
  country                 String?
  photo                   String?
  price                   Int?
  priceVip                Int?
  categoryName            String[]       @default([])
  addedCategory           Boolean        @default(false)
  addedDescription        Boolean        @default(false)
  addedLocation           Boolean        @default(false)
  createdAt               DateTime       @default(now())
  userId                  String?
  municipality            String?
  checkInTime             String?
  contactNumber           String?
  exactAddress            String?
  addedAmenities          Boolean        @default(false)
  approvalRejectionReason String?
  approvedAt              DateTime?
  approvedById            String?
  publishStatus           PublishStatus  @default(DRAFT)
  paymentAmount           Float?
  paymentBank             String?
  paymentDate             DateTime?
  paymentMethod           PaymentMethod?
  paymentReference        String?
  propertyTypeId          Int[]          @default([])
  latitude                Float?
  longitude               Float?
  slug                    String?        @unique
  vipSeats                Int?           @default(0)
  standardSeats           Int?           @default(0)
  Favorite                Favorite[]
  approvedBy              User?          @relation("ApprovedBy", fields: [approvedById], references: [id])
  User                    User?          @relation(fields: [userId], references: [id])
  HomeAmenity             HomeAmenity[]
  Reservation             Reservation[]
  Review                  Review[]
  BlockedDate             BlockedDate[]
  PackageSeat             PackageSeat[]
}

model HomeAmenity {
  id        String        @id
  status    AmenityStatus @default(UNSPECIFIED)
  homeId    String?
  amenityId String?
  createdAt DateTime      @default(now())
  Amenity   Amenity?      @relation(fields: [amenityId], references: [id])
  Home      Home?         @relation(fields: [homeId], references: [id])

  @@unique([homeId, amenityId])
}

model Message {
  id                             String    @id
  content                        String
  createdAt                      DateTime  @default(now())
  isRead                         Boolean   @default(false)
  readAt                         DateTime?
  senderId                       String
  recipientId                    String
  User_Message_recipientIdToUser User      @relation("Message_recipientIdToUser", fields: [recipientId], references: [id], onDelete: Cascade)
  User_Message_senderIdToUser    User      @relation("Message_senderIdToUser", fields: [senderId], references: [id], onDelete: Cascade)
}

model NotificationPreferences {
  id                 String   @id
  userId             String   @unique
  emailOnReservation Boolean  @default(true)
  emailOnReview      Boolean  @default(true)
  emailOnMessage     Boolean  @default(true)
  emailOnPayment     Boolean  @default(true)
  smsNotifications   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  User               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(uuid())
  amount          Float
  serviceFee      Float
  subtotal        Float
  paymentMethod   PaymentMethod
  status          PaymentStatus @default(PENDING)
  bankName        String?
  phoneNumber     String?
  cedula          String?
  referenceNumber String?
  emisorBank      String?
  paymentProofUrl String?
  rejectionReason String?
  paymentDetails  Json?
  createdAt       DateTime      @default(now())
  confirmedAt     DateTime?
  reservationId   String?       @unique
  Reservation     Reservation?  @relation(fields: [reservationId], references: [id])
}

model Reservation {
  id          String            @id @default(uuid())
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime          @default(now())
  userId      String?
  homeId      String?
  nights      Int
  status      ReservationStatus @default(PENDING)
  totalAmount Float
  seatId      String?           @unique
  Payment     Payment?
  Home        Home?             @relation(fields: [homeId], references: [id])
  User        User?             @relation(fields: [userId], references: [id])
  PackageSeat PackageSeat?      @relation(fields: [seatId], references: [id])
  Review      Review?
}

model Review {
  id            String       @id
  rating        Int
  comment       String
  stayStartDate DateTime?
  stayEndDate   DateTime?
  hostReply     String?
  hostReplyAt   DateTime?
  createdAt     DateTime     @default(now())
  homeId        String?
  userId        String?
  reservationId String?      @unique
  Home          Home?        @relation(fields: [homeId], references: [id])
  Reservation   Reservation? @relation(fields: [reservationId], references: [id])
  User          User?        @relation(fields: [userId], references: [id])
}

model User {
  id                                String                   @id @unique
  email                             String
  firstName                         String
  lastName                          String
  profileImage                      String?
  role                              UserRole                 @default(GUEST)
  phoneNumber                       String?
  isVerified                        Boolean                  @default(false)
  verificationReason                String?
  verifiedAt                        DateTime?
  document1Image                    String?
  document2Image                    String?
  verificationStatus                VerificationStatus       @default(NOT_SUBMITTED)
  stateCode                         String?
  municipalityCode                  String?
  AuditLog                          AuditLog[]
  Banner                            Banner[]
  Favorite                          Favorite[]
  ApprovalsGiven                    Home[]                   @relation("ApprovedBy")
  Home                              Home[]
  Message_Message_recipientIdToUser Message[]                @relation("Message_recipientIdToUser")
  Message_Message_senderIdToUser    Message[]                @relation("Message_senderIdToUser")
  NotificationPreferences           NotificationPreferences?
  Reservation                       Reservation[]
  Review                            Review[]
  UserDocument                      UserDocument[]
  usersessions                      usersessions[]
  WithdrawalRequest                 WithdrawalRequest[]
  Saving                            Saving[]
}

model UserDocument {
  id         String   @id @default(uuid())
  userId     String
  url        String
  fileName   String
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model usersessions {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String
  device_id   String
  device_name String?
  os          String?
  browser     String?
  ip_address  String?
  location    String?
  last_active DateTime? @default(now()) @db.Timestamptz(6)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  is_active   Boolean?  @default(true)
  User        User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, device_id])
  @@index([is_active], map: "idx_user_sessions_is_active")
  @@index([user_id], map: "idx_user_sessions_user_id")
}

model PlatformConfig {
  id                 String    @id @default(uuid())
  commissionPercent  Float     @default(10.0)
  bcvRate            Decimal   @default(0.0) @db.Decimal(18, 8)
  bcvRateDate        DateTime?
  bcvProximaRate     Decimal?  @db.Decimal(18, 8)
  bcvProximaRateDate DateTime?
  updatedAt          DateTime  @default(now())
  maintenanceMode    Boolean   @default(false)
}

model BcvRateHistory {
  id            String   @id @default(uuid())
  effectiveDate DateTime @unique
  rate          Decimal  @db.Decimal(18, 8)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlockedDate {
  id        String   @id @default(uuid())
  homeId    String
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
  Home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id             String           @id @default(uuid())
  hostId         String
  amount         Float
  status         WithdrawalStatus @default(PENDING)
  paymentMethod  String?
  paymentDetails Json?
  adminNotes     String?
  createdAt      DateTime         @default(now())
  processedAt    DateTime?
  User           User             @relation(fields: [hostId], references: [id])
}

model Saving {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime @default(now())
  bcvRate        Float
  amountBs       Float
  amountUsd      Float
  paymentDetails Json?
  createdAt      DateTime @default(now())
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model property_types {
  id   Int     @id @default(autoincrement())
  name String
  icon String? @default("home")
}

model PackageSeat {
  id          String      @id @default(uuid())
  homeId      String
  zone        SeatZone
  row         Int
  column      String      // A, B, C o D
  status      SeatStatus  @default(AVAILABLE)
  createdAt   DateTime    @default(now())
  Home        Home        @relation(fields: [homeId], references: [id], onDelete: Cascade)
  Reservation Reservation?

  @@unique([homeId, row, column])
}

enum BannerTipo {
  HERO1
  HERO2
  MEDIO1
  MEDIO2
  POP
}

enum AmenityStatus {
  YES
  NO
  UNSPECIFIED
}

enum PaymentMethod {
  PAGO_MOVIL
  ZELLE
  ZILLI
  TARJETA_INTERNACIONAL
  TRANSFERENCIA_BANCARIA
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum PublishStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum UserRole {
  GUEST
  ADMIN
  SUPERADMIN
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum SeatZone {
  VIP
  STANDARD
}

enum SeatStatus {
  AVAILABLE
  OCCUPIED
}
