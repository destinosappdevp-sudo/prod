// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id String @id @unique

  email         String
  firstName     String
  lastName      String
  profileImage  String?
  phoneNumber   String?
  role          UserRole @default(GUEST)
  Home          Home[]
  Favorite      Favorite[]
  Reservation     Reservation[]
  Review         Review[]
  AuditLog      AuditLog[]
  NotificationPreferences NotificationPreferences?
  MessagesSent  Message[] @relation("SentMessages")
  MessagesReceived Message[] @relation("ReceivedMessages")
}

enum UserRole {
  GUEST
  HOST
  ADMIN
  SUPERADMIN
  BANNER
}
model Banner {
  id           String   @id @default(uuid())
  title        String
  startDate    DateTime
  endDate      DateTime
  url          String
  clientPhone  String
  clientEmail  String
  cost         Float
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdById  String
  createdAt    DateTime @default(now())
  imageUrl     String
  updatedAt    DateTime @updatedAt
}

model Home {
  id String @id @default(uuid())

  title           String?
  description     String?
  guests          String?
  bedrooms        String?   
  bathrooms       String?  
  country         String?
  municipality    String?
  exactAddress    String?
  checkInTime     String?
  contactNumber   String?
  photo           String?
  price           Int?
  categoryName    String?
  Favorite        Favorite[]
  Reservation     Reservation[]
  HomeAmenity     HomeAmenity[]
  Review          Review[]

  addedCategory       Boolean @default(false)
  addedDescription    Boolean @default(false)
  addedAmenities      Boolean @default(false)
  addedLocation       Boolean @default(false)

  createdAt         DateTime @default(now())  
  User              User? @relation(fields: [userId], references: [id])  
  userId            String? 
}

model AmenityCategory {
  id        String    @id @default(uuid())
  name      String
  order     Int?
  isActive  Boolean   @default(true)
  Amenity   Amenity[]
  createdAt DateTime  @default(now())
}

model Amenity {
  id         String    @id @default(uuid())
  name       String
  iconKey    String
  iconUrl    String?
  isActive   Boolean   @default(true)
  category   AmenityCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?
  HomeAmenity HomeAmenity[]
  createdAt  DateTime  @default(now())
}

model HomeAmenity {
  id        String        @id @default(uuid())
  status    AmenityStatus @default(UNSPECIFIED)
  Home      Home?         @relation(fields: [homeId], references: [id])
  homeId    String?
  Amenity   Amenity?      @relation(fields: [amenityId], references: [id])
  amenityId String?
  createdAt DateTime      @default(now())

  @@unique([homeId, amenityId])
}

model Favorite {
  id              String            @id @default(uuid())
  User            User?             @relation(fields: [userId], references: [id])
  userId          String?
  Home            Home?             @relation(fields: [homeId], references: [id])
  homeId          String?

  createAt DateTime @default(now())
}

model Reservation {
  id String @id @default(uuid())

  startDate     DateTime
  endDate       DateTime
  nights        Int
  totalAmount   Float
  status        ReservationStatus @default(PENDING)
  createdAt     DateTime @default(now())

  User            User?             @relation(fields: [userId], references: [id])
  userId          String?
  Home            Home?             @relation(fields: [homeId], references: [id])
  homeId          String?
  Review          Review?
  Payment         Payment?
}

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  serviceFee    Float
  subtotal      Float
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)
  
  // Campos para Pago Móvil y Transferencia
  bankName      String?
  phoneNumber   String?
  cedula        String?
  referenceNumber String?
  emisorBank    String?
  
  // Metadata adicional
  paymentDetails Json?
  
  createdAt     DateTime @default(now())
  confirmedAt   DateTime?
  
  Reservation   Reservation? @relation(fields: [reservationId], references: [id])
  reservationId String?      @unique
}

model Review {
  id             String   @id @default(uuid())
  rating         Int
  comment        String
  stayStartDate  DateTime?
  stayEndDate    DateTime?
  hostReply      String?
  hostReplyAt    DateTime?
  createdAt      DateTime @default(now())

  Home           Home?     @relation(fields: [homeId], references: [id])
  homeId         String?
  User           User?     @relation(fields: [userId], references: [id])
  userId         String?
  Reservation    Reservation? @relation(fields: [reservationId], references: [id])
  reservationId  String?   @unique
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // "PROFILE_UPDATE", "EMAIL_SENT", "RESERVATION_CREATED", "PAYMENT_CONFIRMED"
  userId    String
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreferences {
  id                String   @id @default(uuid())
  userId            String   @unique
  emailOnReservation Boolean @default(true)
  emailOnReview      Boolean @default(true)
  emailOnMessage     Boolean @default(true)
  emailOnPayment     Boolean @default(true)
  smsNotifications   Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(uuid())
  content     String
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)
  readAt      DateTime?
  
  senderId    String
  recipientId String
  
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
}

enum AmenityStatus {
  YES
  NO
  UNSPECIFIED
}

enum PaymentMethod {
  PAGO_MOVIL
  ZELLE
  ZILLI
  TARJETA_INTERNACIONAL
  TRANSFERENCIA_BANCARIA
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
